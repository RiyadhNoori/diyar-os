# ── المثبّت الرسمي (debian-installer) ────────────────────────────────────────
# هذه الأداة هي ما يستخدمه ديبيان الرسمي في صور Live
debian-installer-launcher
localechooser-data

# ── ImageMagick — معالجة الصور ──────────────────────────────────────────────
imagemagick
imagemagick-common

# ── أدوات الأقراص المطلوبة للمثبّت ─────────────────────────────────────────
parted
gdisk
e2fsprogs
dosfstools
uuid-runtime

# ── Grub (أدوات فقط بدون تعارض) ──────────────────────────────────────────────
grub-common
grub2-common
grub-pc-bin
grub-efi-amd64-bin
os-prober

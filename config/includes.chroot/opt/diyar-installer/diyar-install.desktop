[Desktop Entry]
Version=1.0
Type=Application
Name=Install Diyar OS
Name[ar]=تثبيت نظام ديار
GenericName=OS Installer
GenericName[ar]=مثبّت نظام التشغيل
Comment=Install Diyar OS to your hard drive
Comment[ar]=قم بتثبيت نظام ديار على القرص الصلب
Exec=xterm -title "Diyar OS Installer" -fa "Vazirmatn" -fs 12 -e "sudo /usr/local/sbin/diyar-installer ; read -p 'Press Enter to close...'"
Icon=system-installer
Terminal=false
Categories=System;
Keywords=install;setup;diyar;
StartupNotify=true

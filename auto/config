#!/bin/sh
# =============================================================================
# Diyar OS — live-build master configuration
# auto/config
#
# Run: lb config
# This script is called by `lb config` to set all build parameters.
# =============================================================================

set -e

lb config noauto \
    --architectures          amd64 \
    --distribution           bookworm \
    --debian-installer       none \
    --archive-areas          "main contrib non-free non-free-firmware" \
    \
    --binary-images          iso-hybrid \
    --iso-application        "Diyar OS" \
    --iso-publisher          "Diyar OS Project" \
    --iso-volume             "DIYAR_OS_1_0" \
    \
    --bootappend-live        "boot=live components quiet splash locales=ar_IQ.UTF-8 keyboard-layouts=ara,us timezone=Asia/Baghdad" \
    --bootappend-live-failsafe "boot=live components memtest noapic noapm nodma nomce nolapic nosmp nosplash vga=normal" \
    \
    --linux-packages         "linux-image linux-headers" \
    --linux-flavours         amd64 \
    \
    --mirror-bootstrap       "https://deb.debian.org/debian/" \
    --mirror-chroot          "https://deb.debian.org/debian/" \
    --mirror-binary          "https://deb.debian.org/debian/" \
    --mirror-chroot-security "https://security.debian.org/debian-security/" \
    --mirror-binary-security "https://security.debian.org/debian-security/" \
    \
    --apt                    apt \
    --apt-options            "--yes --no-install-recommends" \
    --apt-recommends         false \
    \
    --compression            xz \
    --debootstrap-options    "--include=ca-certificates" \
    \
    --bootloaders            "grub-efi,syslinux" \
    --uefi-secure-boot       disable \
    \
    --chroot-filesystem      squashfs \
    --hdd-label              "DIYAR_OS" \
    \
    --hostname               "diyar-live" \
    --username               "diyar" \
    \
    --win32-loader           false \
    \
    "${@}"
